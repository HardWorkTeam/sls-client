NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api
NEXT_PUBLIC_RSVP_URL=http://localhost:3002
# Shared parent domain for the cross-origin "signed-in" marker cookie read by
# the marketing site. Leave empty in dev (host cookie on localhost, shared
# across ports). In prod set to the shared parent, e.g. .srolanh.com
NEXT_PUBLIC_COOKIE_DOMAIN=
